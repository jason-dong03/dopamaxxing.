{
  "manifest_version": 3,
  "name": "Dopamaxxing",
  "version": "1.0.0",
  "description": "Study to earn crate keys. Track your collection, BR, and coins.",
  "permissions": ["tabs", "storage", "alarms", "idle", "identity"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dopamaxxing"
  },
  "host_permissions": [
    "https://mvdszsvnkvychhzpkvww.supabase.co/*",
    "https://dopamaxxing.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://docs.google.com/document/*",
        "*://docs.google.com/presentation/*",
        "*://docs.google.com/spreadsheets/*",
        "*://docs.google.com/forms/*",
        "*://*.instructure.com/*",
        "*://*.blackboard.com/*",
        "*://*.brightspace.com/*",
        "*://*.moodle.com/*",
        "*://*.moodle.org/*",
        "*://*.moodle.net/*",
        "*://www.coursera.org/*",
        "*://www.edx.org/*",
        "*://www.khanacademy.org/*",
        "*://*.wikipedia.org/wiki/*",
        "*://scholar.google.com/*",
        "*://www.ncbi.nlm.nih.gov/*",
        "*://arxiv.org/abs/*",
        "*://www.jstor.org/*",
        "*://www.notion.so/*",
        "*://quizlet.com/*",
        "*://ankiweb.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
